@page "/go-live"
@namespace PrompterLive.Shared.Pages
@using PrompterLive.Shared.Components.GoLive

<div id="screen-go-live"
     class="screen active"
     data-testid="@UiTestIds.GoLive.Page">
    <div class="go-live-page-shell">
        <section class="go-live-session-bar"
                 data-testid="@UiTestIds.GoLive.SessionBar">
            <div class="go-live-session-bar-left">
                <a class="go-live-back-link" href="@ReadRoute">Back</a>
                <strong>@_screenTitle</strong>
                <span class="go-live-live-badge">@PrimarySessionBadge</span>
            </div>

            <div class="go-live-session-timer">@ProgramTimerLabel</div>

            <div class="go-live-session-actions">
                <button type="button"
                        class="go-live-record-pill"
                        @onclick="ToggleRecordingSessionAsync"
                        disabled="@(!CanControlProgram)"
                        data-testid="@UiTestIds.GoLive.StartRecording">@RecordingBadgeText</button>
                <button type="button"
                        class="go-live-stream-pill"
                        @onclick="ToggleStreamSessionAsync"
                        disabled="@(!CanControlProgram)"
                        data-testid="@UiTestIds.GoLive.StartStream">@StreamActionLabel</button>
            </div>
        </section>

        <section class="go-live-studio-shell">
            <div class="go-live-left-rail">
                <GoLiveSourcesCard Sources="@SceneCameras"
                                   ActiveSourceId="@ActiveCamera?.SourceId"
                                   SelectedSourceId="@SelectedCamera?.SourceId"
                                   SettingsRoute="@AppRoutes.Settings"
                                   HasPrimaryMicrophone="@HasPrimaryMicrophone"
                                   MicrophoneName="@PrimaryMicrophoneLabel"
                                   MicrophoneRouteLabel="@(HasPrimaryMicrophone ? PrimaryMicrophoneRoute : NoMicrophoneLabel)"
                                   SelectSource="SelectSourceAsync"
                                   ToggleSource="ToggleSceneOutputAsync" />
            </div>

            <div class="go-live-center-stage">
                <GoLiveProgramFeedCard ActiveSourceLabel="@ActiveSourceLabel"
                                       ActiveSessionLabel="@ActiveSessionLabel"
                                       Camera="@ActiveCamera"
                                       IsArmed="@HasAnyLiveOutput"
                                       IsRecordingActive="@GoLiveSession.State.IsRecordingActive"
                                       IsStreamActive="@GoLiveSession.State.IsStreamActive"
                                       ProgramResolutionLabel="@ProgramResolutionLabel"
                                       SelectedSourceLabel="@SelectedSourceLabel"
                                       StageFrameRateLabel="@StageFrameRateLabel" />
            </div>

            <aside class="go-live-right-rail"
                   data-testid="@UiTestIds.GoLive.PreviewRail">
                <GoLiveCameraPreviewCard Camera="@ActiveCamera"
                                         CanSwitchProgram="@CanSwitchProgram"
                                         ShowSwitchAction="true"
                                         SwitchActionLabel="@SwitchActionLabel"
                                         SwitchSelectedSource="SwitchSelectedSourceAsync" />

                <section class="go-live-rail-card">
                    <div class="go-live-sidebar-header">
                        <span class="go-live-sidebar-title">Stream</span>
                        <span class="live-status @(HasAnyLiveOutput ? "ready" : "pending")">@ActiveSessionLabel</span>
                    </div>

                    <div class="go-live-stat-grid">
                        <div>
                            <span>Status</span>
                            <strong>@PrimarySessionBadge</strong>
                        </div>
                        <div>
                            <span>Bitrate</span>
                            <strong>@BitrateTelemetry</strong>
                        </div>
                        <div>
                            <span>Resolution</span>
                            <strong>@FormatOutputResolution(_studioSettings.Streaming.OutputResolution)</strong>
                        </div>
                        <div>
                            <span>Dropped</span>
                            <strong>0 frames</strong>
                        </div>
                    </div>

                    <div class="go-live-meter-grid">
                        <div class="go-live-meter-row">
                            <span>Mic</span>
                            <div class="go-live-meter"><span class="go-live-meter-fill go-live-meter-fill-primary"></span></div>
                            <strong>-12 dB</strong>
                        </div>
                        <div class="go-live-meter-row">
                            <span>Sys</span>
                            <div class="go-live-meter"><span class="go-live-meter-fill go-live-meter-fill-secondary"></span></div>
                            <strong>-28 dB</strong>
                        </div>
                        <div class="go-live-meter-row">
                            <span>Bus</span>
                            <div class="go-live-meter"><span class="go-live-meter-fill go-live-meter-fill-tertiary"></span></div>
                            <strong>-16 dB</strong>
                        </div>
                    </div>

                    <div class="go-live-stat-grid go-live-stat-grid-compact">
                        <div>
                            <span>Network</span>
                            <strong>25 ms</strong>
                        </div>
                        <div>
                            <span>Upload</span>
                            <strong>8.0 Mbps</strong>
                        </div>
                        <div>
                            <span>Jitter</span>
                            <strong>3 ms</strong>
                        </div>
                        <div>
                            <span>Packet Loss</span>
                            <strong>0.0%</strong>
                        </div>
                    </div>

                    <div class="go-live-settings-hint">
                        <span class="set-section-label">Configured in Settings</span>
                        <a class="set-btn-outline"
                           href="@AppRoutes.Settings">Manage outputs</a>
                    </div>

                    @if (HasScriptContext)
                    {
                        <div class="live-session-links">
                            <a class="set-btn-outline"
                               href="@LearnRoute"
                               data-testid="@UiTestIds.GoLive.OpenLearn">Open Learn</a>
                            <a class="set-btn-golden"
                               href="@ReadRoute"
                               data-testid="@UiTestIds.GoLive.OpenRead">Open Read</a>
                        </div>
                    }
                </section>
            </aside>
        </section>
    </div>
</div>
