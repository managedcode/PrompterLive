@implements IAsyncDisposable
@namespace PrompterLive.Shared.Components
@using System.Globalization
@using Microsoft.JSInterop
@inject Microsoft.Extensions.Logging.ILogger<SettingsMicrophoneLevelCard> Logger
@inject MicrophoneLevelInterop MicrophoneLevelInterop

<section class="live-card set-media-feedback-card"
         data-testid="@UiTestIds.Settings.MicPreviewCard">
    <div class="live-card-header">
        <div>
            <h4 class="live-card-title">@Title</h4>
            <p class="live-card-desc">@Description</p>
        </div>
        <span class="live-status @(CanMonitor ? ReadyStatusCssClass : PendingStatusCssClass)">
            @(CanMonitor ? ReadyStatusLabel : PendingStatusLabel)
        </span>
    </div>

    @if (CanRenderMonitor)
    {
        <div id="@UiDomIds.Settings.MicrophoneLevelMonitor"
             class="set-mic-monitor"
             data-live-level="@_levelPercent"
             data-live-state="@MonitorState"
             data-testid="@UiTestIds.Settings.MicPreviewMeter">
            <div class="set-mic-monitor-track">
                <div class="set-mic-monitor-fill" style="@MonitorFillStyle"></div>
            </div>
            <div class="set-mic-monitor-readout"
                 data-testid="@UiTestIds.Settings.MicPreviewValue">@MonitorValueText</div>
        </div>

        <div class="set-mic-monitor-meta">
            <div>
                <span class="set-section-label">@PreviewEyebrow</span>
                <div class="set-account-name"
                     data-testid="@UiTestIds.Settings.MicPreviewLabel">@MicrophoneLabel</div>
            </div>
            <div class="live-card-desc">@PreviewDescription</div>
        </div>
    }
    else
    {
        <div class="set-empty-card"
             data-testid="@UiTestIds.Settings.MicPreviewEmpty">
            <div>
                <div class="set-account-name">@EmptyTitle</div>
                <div class="live-card-desc">@EmptyDescription</div>
            </div>
        </div>
    }
</section>

@code {
    private const string DefaultDescription = "Speak into the selected microphone to confirm the browser sees a live signal before recording or streaming.";
    private const string DefaultTitle = "Microphone Activity";
    private const string NoMicrophoneDescription = "Pick a default microphone to see a live level meter here.";
    private const string NoMicrophoneTitle = "No microphone selected";
    private const string PendingStatusCssClass = "pending";
    private const string PendingStatusLabel = "Waiting";
    private const string PermissionDescription = "Enable microphone access in Cameras first, then return here to confirm live input activity.";
    private const string PermissionTitle = "Microphone access required";
    private const string PreviewDescription = "The live meter reflects real browser input, separate from the manual gain slider below.";
    private const string PreviewEyebrow = "PRIMARY MICROPHONE";
    private const string ReadyStatusCssClass = "ready";
    private const string ReadyStatusLabel = "Live level";
    private const string ActiveStateValue = "active";
    private const string IdleStateValue = "idle";
    private const string FillWidthStyleFormat = "width: {0}%;";
    private const string PercentageSuffix = "%";
    private const string StartMonitorFailureMessage = "Failed to start Settings microphone monitor for device {DeviceId}.";
    private const string StopMonitorFailureMessage = "Failed to stop Settings microphone monitor.";

    [Parameter] public bool AccessGranted { get; set; }

    [Parameter] public bool IsActive { get; set; }

    [Parameter] public MediaDeviceInfo? Microphone { get; set; }

    [Parameter] public string Description { get; set; } = DefaultDescription;

    [Parameter] public string Title { get; set; } = DefaultTitle;

    private bool CanMonitor => AccessGranted && IsActive && !string.IsNullOrWhiteSpace(Microphone?.DeviceId);

    private bool CanRenderMonitor => AccessGranted && !string.IsNullOrWhiteSpace(Microphone?.DeviceId);

    private string EmptyDescription =>
        !AccessGranted
            ? PermissionDescription
            : NoMicrophoneDescription;

    private string EmptyTitle =>
        !AccessGranted
            ? PermissionTitle
            : NoMicrophoneTitle;

    private string MicrophoneLabel => Microphone?.Label ?? string.Empty;

    private string? _attachedDeviceId;
    private DotNetObjectReference<MicrophoneLevelObserver>? _observerReference;
    private int _levelPercent;

    private string MonitorFillStyle =>
        string.Format(CultureInfo.InvariantCulture, FillWidthStyleFormat, _levelPercent);

    private string MonitorState => _levelPercent > 0 ? ActiveStateValue : IdleStateValue;

    private string MonitorValueText =>
        string.Concat(_levelPercent.ToString(CultureInfo.InvariantCulture), PercentageSuffix);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            if (!CanMonitor)
            {
                await StopMonitoringAsync();
                return;
            }

            var nextDeviceId = Microphone!.DeviceId;
            if (string.Equals(_attachedDeviceId, nextDeviceId, StringComparison.Ordinal))
            {
                return;
            }

            await StopMonitoringAsync();
            _attachedDeviceId = nextDeviceId;
            _observerReference ??= DotNetObjectReference.Create(new MicrophoneLevelObserver(HandleLevelChangedAsync));
            await MicrophoneLevelInterop.StartAsync(
                UiDomIds.Settings.MicrophoneLevelMonitor,
                nextDeviceId,
                _observerReference);
        }
        catch (Exception exception)
        {
            Microsoft.Extensions.Logging.LoggerExtensions.LogWarning(Logger, exception, StartMonitorFailureMessage, Microphone?.DeviceId);
            _attachedDeviceId = null;
            await HandleLevelChangedAsync(0);
        }
    }

    public async ValueTask DisposeAsync()
    {
        await StopMonitoringAsync();
        _observerReference?.Dispose();
    }

    private async Task StopMonitoringAsync()
    {
        if (string.IsNullOrWhiteSpace(_attachedDeviceId))
        {
            await HandleLevelChangedAsync(0);
            return;
        }

        try
        {
            await MicrophoneLevelInterop.StopAsync(UiDomIds.Settings.MicrophoneLevelMonitor);
        }
        catch (Exception exception)
        {
            Microsoft.Extensions.Logging.LoggerExtensions.LogWarning(Logger, exception, StopMonitorFailureMessage);
        }
        finally
        {
            _attachedDeviceId = null;
            await HandleLevelChangedAsync(0);
        }
    }

    private Task HandleLevelChangedAsync(int levelPercent)
    {
        _levelPercent = Math.Clamp(levelPercent, 0, 100);
        return InvokeAsync(StateHasChanged);
    }
}
