@page "/"
@page "/library"

<div id="screen-library" class="screen active" data-testid="@UiTestIds.Library.Page">
    <LibrarySidebar Folders="_folderNodes"
                    AllScriptCount="_allCards.Count"
                    IsAllSelected="IsAllSelected"
                    OnSelectFolder="SelectFolder"
                    OnStartCreateFolder="StartCreateFolder" />

    <main class="lib-main">
        <div class="lib-scroll">
            <div class="lib-sort-bar">
                <span class="sort-label">Sort by</span>
                <button class="sort-btn @GetSortClass(LibrarySortMode.Name)"
                        @onclick="() => SetSortMode(LibrarySortMode.Name)"
                        data-testid="@UiTestIds.Library.SortName">Name</button>
                <button class="sort-btn @GetSortClass(LibrarySortMode.Date)"
                        @onclick="() => SetSortMode(LibrarySortMode.Date)"
                        data-testid="@UiTestIds.Library.SortDate">Date</button>
                <button class="sort-btn @GetSortClass(LibrarySortMode.Duration)"
                        @onclick="() => SetSortMode(LibrarySortMode.Duration)"
                        data-testid="@UiTestIds.Library.SortDuration">Duration</button>
                <button class="sort-btn @GetSortClass(LibrarySortMode.Wpm)"
                        @onclick="() => SetSortMode(LibrarySortMode.Wpm)"
                        data-testid="@UiTestIds.Library.SortWpm">WPM</button>
            </div>

            <LibraryCardsGrid Cards="_cards"
                              FolderOptions="_folderOptions"
                              OnOpenScript="OpenScriptAsync"
                              OnDuplicateScript="DuplicateScriptAsync"
                              OnMoveScript="MoveScriptAsync"
                              OnDeleteScript="DeleteScriptAsync"
                              OnLearnScript="LearnScriptAsync"
                              OnReadScript="ReadScriptAsync"
                              OnCreateScript="CreateScriptAsync"
                              OnStartCreateFolder="StartCreateFolder" />
        </div>
    </main>
</div>

@if (_isCreatingFolder)
{
    <LibraryFolderCreateModal FolderOptions="@_folderOptions"
                              FolderDraftName="@_folderDraftName"
                              FolderDraftParentId="@_folderDraftParentId"
                              OnCancelCreateFolder="CancelCreateFolder"
                              OnSubmitCreateFolder="SubmitCreateFolderAsync"
                              OnFolderDraftNameChanged="UpdateFolderDraftName"
                              OnFolderDraftParentChanged="UpdateFolderDraftParent" />
}
