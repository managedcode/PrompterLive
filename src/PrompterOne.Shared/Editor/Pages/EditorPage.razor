@page "/editor"
@namespace PrompterOne.Shared.Pages
@using PrompterOne.Shared.Components.Editor

<div id="screen-editor"
     class="screen active"
     data-test="@UiTestIds.Editor.Page">
    @if (!_isEditorReady)
    {
        <div class="app-loading-shell" aria-busy="true">
            <div class="app-loading-mark">PL</div>
        </div>
    }
    else
    {
        <div class="@GetEditorLayoutCss()" data-test="@UiTestIds.Editor.Layout">
            @if (!ShouldShowGraphOnlyWorkspaceChrome)
            {
                <EditorStructureSidebar Segments="@_segments"
                                        ActiveSegmentIndex="@_activeSegmentIndex"
                                        ActiveBlockIndex="@_activeBlockIndex"
                                        OnNavigate="OnNavigateAsync" />
            }

            <div class="editor-workspace">
                @if (!ShouldShowGraphOnlyWorkspaceChrome)
                {
                    <div class="editor-workspace-tabs" data-test="@UiTestIds.Editor.WorkspaceTabs">
                        <button type="button"
                                class="@GetWorkspaceTabCss(EditorWorkspaceTab.Source)"
                                @onclick="() => OnWorkspaceTabChangedAsync(EditorWorkspaceTab.Source)"
                                data-test="@UiTestIds.Editor.SourceTab">
                            @Text(UiTextKey.EditorWorkspaceSourceTab)
                        </button>
                        <button type="button"
                                class="@GetWorkspaceTabCss(EditorWorkspaceTab.Rendered)"
                                @onclick="() => OnWorkspaceTabChangedAsync(EditorWorkspaceTab.Rendered)"
                                data-test="@UiTestIds.Editor.RenderedTab">
                            @Text(UiTextKey.EditorWorkspaceRenderedTab)
                        </button>
                        <button type="button"
                                class="@GetWorkspaceTabCss(EditorWorkspaceTab.Graph)"
                                @onclick="() => OnWorkspaceTabChangedAsync(EditorWorkspaceTab.Graph)"
                                data-test="@UiTestIds.Editor.GraphTab">
                            @Text(UiTextKey.EditorWorkspaceGraphTab)
                        </button>
                    </div>
                }

                <div class="editor-workspace-body">
                    @if (_workspaceTab == EditorWorkspaceTab.Source)
                    {
                        <EditorSourcePanel @key="EditorWorkspaceTab.Source"
                                           @ref="_sourcePanel"
                                           Text="@_sourceText"
                                           Selection="@_selection"
                                           Status="@_status"
                                           CanUndo="@_history.CanUndo"
                                           CanRedo="@_history.CanRedo"
                                           CanApplyWrapCommands="@CanApplyWrapCommands"
                                           CanRenderFloatingToolbar="@CanRenderFloatingToolbar"
                                           ErrorMessage="@_errorMessage"
                                           OnFilesDropped="OnFilesDroppedAsync"
                                           OnTextChanged="OnSourceChangedAsync"
                                           OnSelectionChanged="OnSelectionChangedAsync"
                                           OnHistoryRequested="OnHistoryRequestedAsync"
                                           OnCommandRequested="OnCommandRequestedAsync" />
                    }
                    else if (_workspaceTab == EditorWorkspaceTab.Rendered)
                    {
                        <EditorRenderedTextView Segments="@BuildRenderedSegments()"
                                                FallbackText="@BuildRenderedFallbackText()"
                                                FallbackLabel="@Text(UiTextKey.EditorWorkspaceRenderedTab)"
                                                BlockReorderRequested="OnRenderedBlockReorderRequestedAsync"
                                                TextChanged="OnRenderedTextChangedAsync" />
                    }
                    else
                    {
                        <div @ref="_graphSplitRef"
                             class="@GetGraphSplitCss()"
                             style="@GetGraphSplitStyle()"
                             data-test="@UiTestIds.Editor.GraphSplit"
                             data-mode="@(_graphOnlyMode ? "graph-only" : "split")"
                             data-resizing="@_isGraphSplitDragging.ToString().ToLowerInvariant()"
                             @onpointermove="OnGraphSplitPointerMoveAsync"
                             @onpointerup="OnGraphSplitPointerUpAsync">
                            @if (!_graphOnlyMode)
                            {
                                <div class="editor-graph-source-pane" data-test="@UiTestIds.Editor.GraphSourcePane">
                                    <EditorSourcePanel @key="EditorWorkspaceTab.Graph"
                                                       @ref="_sourcePanel"
                                                       Text="@_sourceText"
                                                       Selection="@_selection"
                                                       Status="@_status"
                                                       CanUndo="@_history.CanUndo"
                                                       CanRedo="@_history.CanRedo"
                                                       CanApplyWrapCommands="@CanApplyWrapCommands"
                                                       CanRenderFloatingToolbar="@CanRenderFloatingToolbar"
                                                       ErrorMessage="@_errorMessage"
                                                       OnFilesDropped="OnFilesDroppedAsync"
                                                       OnTextChanged="OnSourceChangedAsync"
                                                       OnSelectionChanged="OnSelectionChangedAsync"
                                                       OnHistoryRequested="OnHistoryRequestedAsync"
                                                       OnCommandRequested="OnCommandRequestedAsync" />
                                </div>
                                <button type="button"
                                        class="editor-graph-split-resizer"
                                        aria-label="@Text(UiTextKey.EditorGraphResizeDivider)"
                                        data-test="@UiTestIds.Editor.GraphSplitResizer"
                                        @onpointerdown="OnGraphSplitPointerDownAsync"
                                        @onpointerup="OnGraphSplitPointerUpAsync">
                                    <span aria-hidden="true"></span>
                                </button>
                            }
                            <ScriptGraphPanel Artifact="@_scriptGraphArtifact"
                                              IsLoading="@_isGraphLoading"
                                              LayoutMode="@_graphLayoutMode"
                                              LayoutModeChanged="OnGraphLayoutModeChanged"
                                              NodeStyleMode="@_graphNodeStyleMode"
                                              IsGraphOnly="@_graphOnlyMode"
                                              IsGraphOnlyChanged="OnGraphOnlyModeChanged"
                                              AnalyzeRequested="OnGraphAnalyzeRequestedAsync"
                                              TokenizerAnalysisRequested="OnGraphTokenizerAnalysisRequestedAsync"
                                              SourceRangeRequested="OnGraphSourceRangeRequestedAsync" />
                        </div>
                    }

                    @if (!ShouldShowGraphOnlyWorkspaceChrome)
                    {
                        <EditorMetadataRail Profile="@_profile"
                                            Title="@_screenTitle"
                                            BaseWpm="@_baseWpm"
                                            Duration="@_displayDuration"
                                            XslowOffset="@_xslowOffset"
                                            SlowOffset="@_slowOffset"
                                            FastOffset="@_fastOffset"
                                            XfastOffset="@_xfastOffset"
                                            Author="@_author"
                                            CreatedDate="@_createdDate"
                                            Version="@_version"
                                            Status="@_status"
                                            AutoSaveEnabled="@_fileStorageSettings.FileAutoSaveEnabled"
                                            LastLocalSaveAt="@_lastLocalSaveAt"
                                            LocalHistory="@_localHistory"
                                            SplitFeedback="@_splitFeedback"
                                            ProfileChanged="OnProfileChangedAsync"
                                            TitleChanged="OnTitleChangedAsync"
                                            BaseWpmChanged="OnBaseWpmChangedAsync"
                                            DurationChanged="OnDurationChangedAsync"
                                            XslowOffsetChanged="OnXslowOffsetChangedAsync"
                                            SlowOffsetChanged="OnSlowOffsetChangedAsync"
                                            FastOffsetChanged="OnFastOffsetChangedAsync"
                                            XfastOffsetChanged="OnXfastOffsetChangedAsync"
                                            AuthorChanged="OnAuthorChangedAsync"
                                            CreatedDateChanged="OnCreatedDateChangedAsync"
                                            VersionChanged="OnVersionChangedAsync"
                                            LocalHistoryRestoreRequested="OnLocalHistoryRestoreRequestedAsync"
                                            OpenLibraryRequested="OnOpenLibraryRequested"
                                            SplitRequested="OnSplitRequestedAsync"
                                            SelectedTab="@_metadataRailSelectedTab"
                                            SelectedTabChanged="OnMetadataRailTabChanged"
                                            ShowGraphTab="@(_workspaceTab == EditorWorkspaceTab.Graph)"
                                            GraphLayoutMode="@_graphLayoutMode"
                                            GraphLayoutModeChanged="OnGraphLayoutModeChanged"
                                            GraphNodeStyleMode="@_graphNodeStyleMode"
                                            GraphNodeStyleModeChanged="OnGraphNodeStyleModeChanged"
                                            IsCollapsed="@_isMetadataRailCollapsed"
                                            ToggleLabel="@GetMetadataRailToggleLabel()"
                                            ToggleRequested="OnMetadataRailToggleAsync" />
                    }
                </div>
            </div>
        </div>
    }
</div>
