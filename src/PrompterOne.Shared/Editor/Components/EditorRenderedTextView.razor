@namespace PrompterOne.Shared.Components.Editor
@using Microsoft.Extensions.Localization
@using PrompterOne.Shared.Localization
@inject IStringLocalizer<SharedResource> Localizer

<div class="editor-rendered-view"
     data-rendered-authoring-mode="styled-text"
     data-test="@UiTestIds.Editor.RenderedView">
    <div class="editor-rendered-document" data-test="@UiTestIds.Editor.RenderedStrip">
        @if (Segments.Count == 0)
        {
            <section class="editor-rendered-section editor-rendered-section--empty" data-test="@UiTestIds.Editor.RenderedEmpty">
                <textarea class="editor-rendered-text editor-rendered-text--empty"
                          aria-label="@FallbackLabel"
                          data-test="@UiTestIds.Editor.RenderedFallbackText"
                          value="@FallbackText"
                          @oninput="OnFallbackInputAsync"></textarea>
            </section>
        }
        else
        {
            @foreach (var segment in Segments)
            {
                <section class="editor-rendered-section" data-test="@UiTestIds.Editor.RenderedSegment(segment.Index)">
                    <header class="editor-rendered-section-header">
                        <span class="editor-rendered-number">@segment.Number</span>
                        <div class="editor-rendered-section-title-group">
                            <h2 class="editor-rendered-segment-title">@segment.Name</h2>
                            <div class="editor-rendered-cue-row editor-rendered-cue-row--segment"
                                 aria-label="@segment.Name"
                                 data-test="@UiTestIds.Editor.RenderedSegmentCues(segment.Index)">
                                @foreach (var cue in segment.Cues)
                                {
                                    <span class="editor-rendered-cue-chip"
                                          data-cue-kind="@cue.Kind"
                                          data-cue-tone="@cue.Tone">
                                        <span class="editor-rendered-cue-icon" aria-hidden="true">@cue.Icon</span>
                                        <span class="editor-rendered-cue-label">@cue.Label</span>
                                    </span>
                                }
                            </div>
                        </div>
                    </header>

                    @foreach (var block in segment.Blocks)
                    {
                        <article class="editor-rendered-block"
                                 draggable="false"
                                 data-rendered-segment-index="@block.SegmentIndex"
                                 data-rendered-block-index="@block.BlockIndex"
                                 data-test="@UiTestIds.Editor.RenderedBlock(block.SegmentIndex, block.BlockIndex)">
                            <div class="editor-rendered-block-head">
                                <span class="editor-rendered-block-number">@block.Number</span>
                                <span class="editor-rendered-block-title">@block.Name</span>
                                <span class="editor-rendered-block-cue-line"
                                      data-test="@UiTestIds.Editor.RenderedBlockCues(block.SegmentIndex, block.BlockIndex)">
                                    @foreach (var cue in block.Cues)
                                    {
                                        <span class="editor-rendered-cue-chip"
                                              data-cue-kind="@cue.Kind"
                                              data-cue-tone="@cue.Tone">
                                            <span class="editor-rendered-cue-icon" aria-hidden="true">@cue.Icon</span>
                                            <span class="editor-rendered-cue-label">@cue.Label</span>
                                        </span>
                                    }
                                </span>
                            </div>
                            <textarea class="editor-rendered-text"
                                      aria-label="@block.Name"
                                      data-test="@UiTestIds.Editor.RenderedBlockText(block.SegmentIndex, block.BlockIndex)"
                                      value="@block.Text"
                                      @oninput="@((ChangeEventArgs args) => OnBlockInputAsync(block, args))"></textarea>
                        </article>
                    }
                </section>
            }
        }
    </div>
</div>

@code {
    [Parameter] public string FallbackText { get; set; } = string.Empty;

    [Parameter] public string FallbackLabel { get; set; } = string.Empty;

    [Parameter] public IReadOnlyList<EditorRenderedSegmentViewModel> Segments { get; set; } = [];

    [Parameter] public EventCallback<EditorRenderedBlockTextChange> TextChanged { get; set; }

    [Parameter] public EventCallback<EditorRenderedBlockReorderRequest> BlockReorderRequested { get; set; }

    [Parameter] public EventCallback<EditorRenderedBlockAttachmentRequest> AttachmentRequested { get; set; }

    private Task OnBlockInputAsync(EditorRenderedBlockViewModel block, ChangeEventArgs args) =>
        TextChanged.InvokeAsync(new EditorRenderedBlockTextChange(
            block.SegmentIndex,
            block.BlockIndex,
            args.Value?.ToString() ?? string.Empty));

    private Task OnFallbackInputAsync(ChangeEventArgs args) =>
        TextChanged.InvokeAsync(new EditorRenderedBlockTextChange(
            0,
            0,
            args.Value?.ToString() ?? string.Empty));

    private string Text(UiTextKey key) => Localizer[key.ToString()];
}
