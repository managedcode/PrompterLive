@namespace PrompterOne.Shared.Components
@using PrompterOne.Shared.Contracts

<span class="@BuildAnchorCssClass()"
      @onmouseenter="HandlePointerEnter"
      @onmouseleave="HandlePointerLeave"
      @onfocusin="HandleFocusIn"
      @onfocusout="HandleFocusOut"
      @onpointerdown="HandlePointerDown"
      @onkeydown="HandleKeyDown"
      data-test="@UiTestIds.Tooltip.Anchor(OwnerTestId)">
    @ChildContent
    <span id="@UiDomIds.Tooltip.Surface(OwnerTestId)"
          class="@BuildTooltipCssClass()"
          role="tooltip"
          data-visible="@(BuildTooltipVisibilityValue())"
          data-test="@UiTestIds.Tooltip.Surface(OwnerTestId)"
          data-tooltip-placement="@BuildPlacementValue()">@Text</span>
</span>

@code {
    [Parameter]
    public string AnchorClass { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public RenderFragment ChildContent { get; set; } = default!;

    [Parameter, EditorRequired]
    public string OwnerTestId { get; set; } = string.Empty;

    [Parameter]
    public TooltipPlacement Placement { get; set; } = TooltipPlacement.TopCenter;

    [Parameter, EditorRequired]
    public string Text { get; set; } = string.Empty;

    private bool _isTooltipVisible;
    private bool _isTooltipSuppressedUntilPointerLeave;

    private string BuildAnchorCssClass() =>
        string.IsNullOrWhiteSpace(AnchorClass)
            ? TooltipCssClass
            : $"{TooltipCssClass} {AnchorClass}";

    private string BuildPlacementCssClass() =>
        Placement switch
        {
            TooltipPlacement.LeftCenter => $"{TooltipSurfaceCssClass} {TooltipLeftCssClass}",
            TooltipPlacement.RightCenter => $"{TooltipSurfaceCssClass} {TooltipRightCssClass}",
            _ => $"{TooltipSurfaceCssClass} {TooltipTopCssClass}"
        };

    private string BuildPlacementValue() =>
        Placement switch
        {
            TooltipPlacement.LeftCenter => LeftPlacementValue,
            TooltipPlacement.RightCenter => RightPlacementValue,
            _ => TopPlacementValue
        };

    private string BuildTooltipCssClass() =>
        _isTooltipVisible
            ? $"{BuildPlacementCssClass()} {TooltipVisibleCssClass}"
            : BuildPlacementCssClass();

    private string BuildTooltipVisibilityValue() =>
        _isTooltipVisible ? VisibleStateValue : HiddenStateValue;

    private void HandleFocusIn()
    {
        if (_isTooltipSuppressedUntilPointerLeave)
        {
            return;
        }

        _isTooltipVisible = true;
    }

    private void HandleFocusOut() => _isTooltipVisible = false;

    private void HandleKeyDown(KeyboardEventArgs args)
    {
        var normalizedKey = UiKeyboardKeys.Normalize(args.Key);
        if (string.Equals(normalizedKey, UiKeyboardKeys.Enter, StringComparison.Ordinal) ||
            string.Equals(normalizedKey, UiKeyboardKeys.Escape, StringComparison.Ordinal) ||
            string.Equals(normalizedKey, UiKeyboardKeys.Space, StringComparison.Ordinal))
        {
            _isTooltipVisible = false;
        }
    }

    private void HandlePointerDown()
    {
        _isTooltipVisible = false;
        _isTooltipSuppressedUntilPointerLeave = true;
    }

    private void HandlePointerEnter()
    {
        if (_isTooltipSuppressedUntilPointerLeave)
        {
            return;
        }

        _isTooltipVisible = true;
    }

    private void HandlePointerLeave()
    {
        _isTooltipVisible = false;
        _isTooltipSuppressedUntilPointerLeave = false;
    }

    private const string LeftPlacementValue = "left";
    private const string RightPlacementValue = "right";
    private const string TopPlacementValue = "top";
    private const string HiddenStateValue = "false";
    private const string TooltipCssClass = "po-tooltip-anchor";
    private const string TooltipLeftCssClass = "po-tooltip-surface--left";
    private const string TooltipRightCssClass = "po-tooltip-surface--right";
    private const string TooltipSurfaceCssClass = "po-tooltip-surface";
    private const string TooltipTopCssClass = "po-tooltip-surface--top";
    private const string TooltipVisibleCssClass = "po-tooltip-surface--visible";
    private const string VisibleStateValue = "true";
}
