@namespace PrompterOne.Shared.Components.Settings
@using PrompterOne.Core.Models.Streaming
@using PrompterOne.Core.Models.Workspace
@using PrompterOne.Shared.Settings.Components
@using PrompterOne.Shared.Settings.Models

<div class="set-subsection">
    <h4 class="set-sub-title">@SettingsStreamingText.OutputDefaultsTitle</h4>
    <div class="set-devices">
        <div class="set-field">
            <label>@SettingsStreamingText.OutputModeLabel</label>
            <SettingsSelect Value="@SelectedOutputModeValue"
                           Options="@OutputModeOptions"
                           OnChange="OutputModeChanged"
                           TestId="@UiTestIds.Settings.StreamingOutputMode" />
        </div>
        <div class="set-field">
            <label>@SettingsStreamingText.OutputResolutionLabel</label>
            <SettingsSelect Value="@Settings.OutputResolution.ToString()"
                           Options="@OutputResolutionOptions"
                           OnChange="OutputResolutionChanged"
                           TestId="@UiTestIds.Settings.StreamingOutputResolution" />
        </div>
        <div class="set-field">
            <label>@SettingsStreamingText.BitrateLabel</label>
            <input type="number"
                   class="set-input"
                   value="@Settings.BitrateKbps"
                   @oninput="BitrateChanged"
                   data-testid="@UiTestIds.Settings.StreamingBitrate" />
        </div>
        <div class="set-field set-field-toggle">
            <label>@SettingsStreamingText.ShowTextOverlayLabel</label>
            <div class="set-toggle @(Settings.ShowTextOverlay ? OnCssClass : null)"
                 @onclick="ToggleTextOverlay"
                 data-testid="@UiTestIds.Settings.StreamingTextOverlay">
                <div class="set-toggle-thumb"></div>
            </div>
        </div>
        <div class="set-field set-field-toggle">
            <label>@SettingsStreamingText.IncludeCameraInOutputLabel</label>
            <div class="set-toggle @(Settings.IncludeCameraInOutput ? OnCssClass : null)"
                 @onclick="ToggleIncludeCamera"
                 data-testid="@UiTestIds.Settings.StreamingIncludeCamera">
                <div class="set-toggle-thumb"></div>
            </div>
        </div>
    </div>
</div>

<div class="set-sub-header" style="margin-bottom:14px">
    <h4 class="set-sub-title">@SettingsStreamingText.DestinationsTitle</h4>
    <button class="set-btn-outline set-btn-sm"
            type="button"
            data-testid="@UiTestIds.Settings.StreamingDestinationAdd"
            @onclick="ToggleDestinationMenu">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="12" y1="5" x2="12" y2="19" />
            <line x1="5" y1="12" x2="19" y2="12" />
        </svg>
        @SettingsStreamingText.AddDestinationButtonLabel
    </button>
</div>

<div class="@AddDestinationMenuCssClass">
    @foreach (var platform in StreamingPlatformCatalog.All)
    {
        <button class="set-add-source-opt"
                type="button"
                data-testid="@UiTestIds.Settings.StreamingDestinationAddOption(platform.IdPrefix)"
                @onclick="@(() => AddDestinationAndOpenCardAsync(platform.Kind))">
            @platform.DisplayName
        </button>
    }
</div>

<div class="set-device-list">
    @foreach (var localTarget in LocalTargetCards)
        {
            <SettingsStreamingTargetCard Title="@localTarget.Name"
                                     Account="@localTarget.AccountLabel"
                                     Description="@localTarget.Description"
                                     Summary="@BuildLocalSummary(localTarget.TargetId)"
                                     StatusLabel="@BuildLocalTargetStatusLabel(localTarget.TargetId)"
                                     StatusClass="@BuildLocalTargetStatusClass(localTarget.TargetId)"
                                     IsEnabled="@IsLocalTargetEnabled(localTarget.TargetId)"
                                     IsOpen="@IsCardOpen(localTarget.CardId)"
                                     IsReady="@BuildLocalTargetIsReady(localTarget.TargetId)"
                                     ToggleTestId="@localTarget.ToggleTestId"
                                     CardTestId="@UiTestIds.Settings.StreamingProviderCard(localTarget.TargetId)"
                                     ToggleEnabled="@(() => ToggleLocalTargetAsync(localTarget.TargetId))"
                                     OnCardToggle="@(() => ToggleStreamingCardAsync(localTarget.CardId))">
            <div class="set-field set-field-toggle">
                <label>@SettingsStreamingText.AvailableInProgramRoutingLabel</label>
                <span class="set-dest-status @(BuildLocalTargetIsReady(localTarget.TargetId) ? SelectedStatusClass : string.Empty)">
                    @BuildLocalSummary(localTarget.TargetId)
                </span>
            </div>
        </SettingsStreamingTargetCard>
    }

    @foreach (var destination in ExternalDestinations)
    {
        <SettingsStreamingExternalDestinationCard Settings="@Settings"
                                                 Destination="@destination"
                                                 Sources="@Sources"
                                                 IsCardOpen="IsCardOpen"
                                                 ToggleCard="ToggleCard"
                                                 ToggleDestination="ToggleExternalDestination"
                                                 RemoveDestination="RemoveExternalDestination"
                                                 ToggleDestinationSource="ToggleDestinationSource"
                                                 UpdateField="UpdateExternalDestinationField" />
    }
</div>
