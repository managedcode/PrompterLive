@namespace PrompterOne.Shared.Components.Settings
@using System.Globalization
@using Microsoft.Extensions.Localization
@using PrompterOne.Shared.Localization
@using PrompterOne.Shared.Services
@using PrompterOne.Shared.Settings.Models
@inject IStringLocalizer<SharedResource> Localizer

<section class="live-destination-sources"
         data-testid="@UiTestIds.Settings.StreamingProviderSourcePicker(TargetId)">
    <div class="live-destination-sources-header">
        <span class="set-section-label">@Text(SettingsStreamingText.SourcePickerSectionLabel)</span>
        <span class="live-status @(SelectedCount > 0 ? ReadyCssClass : PendingCssClass)"
              data-testid="@UiTestIds.Settings.StreamingProviderSourceSummary(TargetId)">
            @SourceSummary
        </span>
    </div>

    @if (Sources.Count == 0)
    {
        <div class="set-empty-card live-destination-sources-empty"
             data-testid="@UiTestIds.Settings.StreamingSourcePickerEmpty">
            @Text(SettingsStreamingText.SourcePickerEmptyStateMessage)
        </div>
    }
    else
    {
        <div class="live-destination-source-grid">
            @foreach (var source in Sources)
            {
                var isSelected = SelectedSourceIdSet.Contains(source.SourceId);
                <button type="button"
                        class="live-destination-source-chip @(isSelected ? ChipEnabledCssClass : null)"
                        data-testid="@UiTestIds.Settings.StreamingProviderSourceToggle(TargetId, source.SourceId)"
                        @onclick="() => ToggleSource.InvokeAsync(source.SourceId)">
                    <span class="live-destination-source-name">@FormatSourceLabel(source)</span>
                    <span class="live-destination-source-state">@(isSelected ? Text(SettingsStreamingText.SourcePickerSelectedLabel) : Text(SettingsStreamingText.SourcePickerAvailableLabel))</span>
                </button>
            }
        </div>
    }
</section>

@code {
    private const string ChipEnabledCssClass = "on";
    private const string PendingCssClass = "pending";
    private const string ReadyCssClass = "ready";

    [Parameter] public IReadOnlyList<SceneCameraSource> Sources { get; set; } = [];
    [Parameter] public IReadOnlyList<string> SelectedSourceIds { get; set; } = [];
    [Parameter] public string TargetId { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> ToggleSource { get; set; }

    private int SelectedCount => SelectedSourceIdSet.Count;

    private HashSet<string> SelectedSourceIdSet => SelectedSourceIds.ToHashSet(StringComparer.Ordinal);
    private static string FormatSourceLabel(SceneCameraSource source) => MediaDeviceLabelSanitizer.Sanitize(source.Label);

    private string SourceSummary =>
        SelectedCount switch
        {
            0 => Text(SettingsStreamingText.SourcePickerNoCamerasSelectedLabel),
            1 => Format(SettingsStreamingText.SourcePickerSingleCameraSelectedFormat, SelectedCount),
            _ => Format(SettingsStreamingText.SourcePickerMultipleCamerasSelectedFormat, SelectedCount)
        };

    private string Format(string key, params object[] arguments) =>
        string.Format(CultureInfo.CurrentCulture, Text(key), arguments);

    private string Text(string key) => Localizer[key];
}
