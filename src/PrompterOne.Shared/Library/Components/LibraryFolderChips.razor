@namespace PrompterOne.Shared.Components.Library
@if (Chips.Count > 0)
{
    <div class="lib-folders" data-test="@UiTestIds.Library.FolderChips">
        @foreach (var chip in Chips)
        {
            <button class="@BuildChipCssClass(chip)"
                    @onclick="() => OnSelectFolder.InvokeAsync(chip.Id)"
                    data-active="@(chip.IsSelected ? ActiveStateValue : InactiveStateValue)"
                    data-test="@chip.TestId">
                <span>@chip.Name</span>
                <span class="folder-count">@chip.TotalCount</span>
            </button>
        }
    </div>
}

@code {
    private const string ActiveStateValue = "active";
    private const string InactiveStateValue = "inactive";

    [Parameter, EditorRequired] public IReadOnlyList<LibraryFolderChipViewModel> Chips { get; set; } = [];

    [Parameter, EditorRequired] public EventCallback<string> OnSelectFolder { get; set; }

    private static string BuildChipCssClass(LibraryFolderChipViewModel chip) =>
        chip.IsSelected ? "folder-chip active" : "folder-chip";
}
