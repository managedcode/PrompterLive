@namespace PrompterOne.Shared.Components.GoLive
@using PrompterOne.Core.Models.Media

<section class="gl-program-monitor-shell"
         data-live-state="@LiveState">
    <div class="gl-monitor-label-top gl-label-canvas">
        <span>@Title</span>
        <span class="gl-program-session-copy">@ActiveSessionLabel</span>
    </div>

    <div class="gl-monitor gl-monitor-program"
         data-testid="@UiTestIds.GoLive.ProgramCard">
        <GoLiveCameraSurface Camera="@Camera"
                             ContainerClass="gl-monitor-feed"
                             ContainerDomId="@UiDomIds.GoLive.ProgramStage"
                             VideoClass="gl-program-video"
                             VideoDomId="@UiDomIds.GoLive.ProgramVideo"
                             VideoTestId="@UiTestIds.GoLive.ProgramVideo">
            <OverlayContent>
                <div class="gl-program-overlay">
                    <span class="gl-program-reader-tag">@SelectedLabel</span>
                </div>
            </OverlayContent>
            <EmptyContent>
                <div class="gl-preview-empty"
                     data-testid="@UiTestIds.GoLive.ProgramEmpty">
                    <div class="gl-empty-title">@NoCameraTitle</div>
                    <div class="gl-empty-copy">@NoCameraDescription</div>
                </div>
            </EmptyContent>
        </GoLiveCameraSurface>

        <div class="gl-monitor-bottom">
            <span class="gl-monitor-res">@ProgramResolutionLabel</span>
            <span class="gl-monitor-source"
                  data-testid="@UiTestIds.GoLive.Stage">
                <span data-testid="@UiTestIds.GoLive.SelectedSourceLabel">@SelectedSourceLabel</span>
            </span>
            <span class="gl-monitor-fps">@StageFrameRateLabel</span>
        </div>
    </div>

    <div class="gl-monitor-info">
        <span class="gl-monitor-info-label">@LiveLabel</span>
        <strong data-testid="@UiTestIds.GoLive.ActiveSourceLabel">@ActiveSourceLabel</strong>
        <span class="gl-monitor-info-sep"></span>
        <span class="gl-monitor-info-label">@CanvasLabel</span>
        <strong>@SelectedSourceLabel</strong>
    </div>
</section>

@code {
    private const string CanvasLabel = "Canvas";
    private const string DefaultTitle = "Canvas";
    private const string IdleStateCss = "idle";
    private const string LiveLabel = "On Air";
    private const string NoCameraDescription = "Select or add a camera source to build the live canvas.";
    private const string NoCameraTitle = "No canvas source";
    private const string RecordingStateCss = "recording";
    private const string SelectedLabel = "Selected";
    private const string StreamingStateCss = "streaming";

    [Parameter] public string ActiveSessionLabel { get; set; } = string.Empty;
    [Parameter] public string ActiveSourceLabel { get; set; } = string.Empty;
    [Parameter] public SceneCameraSource? Camera { get; set; }
    [Parameter] public bool IsRecordingActive { get; set; }
    [Parameter] public bool IsStreamActive { get; set; }
    [Parameter] public string ProgramResolutionLabel { get; set; } = string.Empty;
    [Parameter] public string SelectedSourceLabel { get; set; } = string.Empty;
    [Parameter] public string StageFrameRateLabel { get; set; } = string.Empty;
    [Parameter] public string Title { get; set; } = DefaultTitle;

    private string LiveState => IsRecordingActive
        ? RecordingStateCss
        : IsStreamActive
            ? StreamingStateCss
            : IdleStateCss;
}
