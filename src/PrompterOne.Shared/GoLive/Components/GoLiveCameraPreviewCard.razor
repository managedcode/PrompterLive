@namespace PrompterOne.Shared.Components.GoLive
@using PrompterOne.Shared.Services

<section id="@UiDomIds.GoLive.PreviewCard"
         class="gl-preview-section"
         data-test="@UiTestIds.GoLive.PreviewCard">
    <div class="gl-monitor gl-monitor-preview">
        <GoLiveCameraSurface Camera="@Camera"
                             ContainerClass="gl-monitor-feed gl-preview-feed"
                             ContainerDomId="@UiDomIds.GoLive.PreviewStage"
                             VideoClass="gl-preview-video"
                             VideoDomId="@UiDomIds.GoLive.PreviewVideo"
                             VideoTestId="@UiTestIds.GoLive.PreviewVideo">
            <OverlayContent>
                <div class="gl-preview-overlay">
                    <div class="gl-preview-caption">
                        <span class="gl-preview-label">@Title</span>
                        <strong data-test="@UiTestIds.GoLive.PreviewSourceLabel">@CameraLabel</strong>
                    </div>
                </div>
            </OverlayContent>
            <EmptyContent>
                <div id="@UiDomIds.GoLive.PreviewEmpty"
                     class="gl-preview-empty"
                     data-test="@UiTestIds.GoLive.PreviewEmpty">
                    <div class="gl-preview-empty-title">@ResolvedEmptyTitle</div>
                    <div class="gl-preview-empty-copy">@ResolvedEmptyDescription</div>
                </div>
            </EmptyContent>
        </GoLiveCameraSurface>
        <div class="gl-air-dot-wrap">
            <span class="gl-air-dot @(ShowLiveDot ? LiveDotCssClass : null)"
                  data-test="@UiTestIds.GoLive.PreviewLiveDot"
                  data-live-state="@PreviewIndicatorState"></span>
        </div>
    </div>
</section>

@code {
    private const string DefaultDescription = "Preview the current live scene camera before arming or switching destinations.";
    private const string DefaultTitle = "Preview";
    private const string DefaultEmptyDescription = "Add a scene camera in Settings or include one in the live output to preview it here.";
    private const string DefaultEmptyTitle = "No camera";
    private const string IdleStateValue = "idle";
    private const string LiveDotCssClass = "gl-air-dot-live";

    [Parameter] public SceneCameraSource? Camera { get; set; }
    [Parameter] public bool CanSwitchProgram { get; set; }
    [Parameter] public string Description { get; set; } = DefaultDescription;
    [Parameter] public string EmptyDescription { get; set; } = string.Empty;
    [Parameter] public string EmptyTitle { get; set; } = string.Empty;
    [Parameter] public string LiveState { get; set; } = IdleStateValue;
    [Parameter] public bool ShowSwitchAction { get; set; }
    [Parameter] public EventCallback SwitchSelectedSource { get; set; }
    [Parameter] public string SwitchActionLabel { get; set; } = string.Empty;
    [Parameter] public string Title { get; set; } = DefaultTitle;

    private bool HasCamera => Camera is not null;
    private string CameraLabel => Camera is null ? string.Empty : MediaDeviceLabelSanitizer.Sanitize(Camera.Label);

    private string ResolvedEmptyDescription => string.IsNullOrWhiteSpace(EmptyDescription)
        ? DefaultEmptyDescription
        : EmptyDescription;

    private string ResolvedEmptyTitle => string.IsNullOrWhiteSpace(EmptyTitle)
        ? DefaultEmptyTitle
        : EmptyTitle;

    private string PreviewIndicatorState => ShowLiveDot
        ? LiveState
        : IdleStateValue;

    private bool ShowLiveDot => HasCamera && !string.Equals(LiveState, IdleStateValue, StringComparison.Ordinal);
}
