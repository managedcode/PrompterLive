@page "/learn"
@page "/prep"
@namespace PrompterOne.Shared.Pages
@using PrompterOne.Shared.Components
@using PrompterOne.Shared.Contracts

<HeadContent>
    <link rel="stylesheet" href="@DesignStylesheetPaths.Learn" />
</HeadContent>

<div id="@UiDomIds.Design.LearnScreen"
     class="screen active"
     tabindex="0"
     @ref="_screenRoot"
     @onkeydown="HandleLearnKeyDownAsync"
     @onkeydown:preventDefault="true"
     data-test="@UiTestIds.Learn.Page">
    <div class="rsvp">
        <div class="rsvp-progress">
            <UiPercentFill id="@UiDomIds.Learn.ProgressFill"
                           Class="rsvp-progress-fill"
                           Percent="@_progressPercent"
                           data-test="@UiTestIds.Learn.ProgressFill" />
        </div>

        <div class="rsvp-display"
             @ref="_displayRoot"
             data-rsvp-layout-ready="@BuildLayoutReadyAttributeValue()"
             data-test="@UiTestIds.Learn.Display">
            <div style="@BuildPendingLayoutHiddenStyle()">
                <div class="rsvp-crosshair">
                    <UiCrosshairGuide TestId="@UiTestIds.Learn.Crosshair" />
                </div>

                <div class="rsvp-h-row" @ref="_focusRow" data-test="@UiTestIds.Learn.FocusRow">
                    <div class="rsvp-active-phrase-highlight"
                         aria-hidden="true"
                         data-test="@UiTestIds.Learn.ActivePhraseHighlight"></div>
                    <div class="rsvp-lane rsvp-lane-left">
                        <div class="rsvp-ctx-left" id="@UiDomIds.Learn.ContextLeft" data-test="@UiTestIds.Learn.ContextLeft">
                            @foreach (var word in _leftContextWords)
                            {
                                <span>@word</span>
                            }
                        </div>
                    </div>

                    <div class="rsvp-focus-shell"
                         id="@UiDomIds.Learn.WordShell"
                         data-test="@UiTestIds.Learn.WordShell">
                        <div class="rsvp-focus"
                             id="@UiDomIds.Learn.Word"
                             @ref="_focusWord"
                             data-test="@UiTestIds.Learn.Word">
                            <span class="rsvp-focus-segment rsvp-focus-leading" data-test="@UiTestIds.Learn.WordLeading">@_currentWordLeading</span>
                            <span class="rsvp-focus-segment rsvp-focus-orp orp" @ref="_focusOrp" data-test="@UiTestIds.Learn.WordOrp">@_currentWordOrp</span>
                            <span class="rsvp-focus-segment rsvp-focus-trailing" data-test="@UiTestIds.Learn.WordTrailing">@_currentWordTrailing</span>
                        </div>
                    </div>

                    <div class="rsvp-lane rsvp-lane-right">
                        <div class="rsvp-ctx-right" id="@UiDomIds.Learn.ContextRight" data-test="@UiTestIds.Learn.ContextRight">
                            @foreach (var word in _rightContextWords)
                            {
                                <span>@word</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="rsvp-orp-line" data-test="@UiTestIds.Learn.OrpLine"></div>
            </div>

            <div class="rsvp-phrase">
                <span class="rsvp-phrase-label">@Text(UiTextKey.LearnNext)</span>
                <p id="@UiDomIds.Learn.NextPhrase" data-test="@UiTestIds.Learn.NextPhrase">@_nextPhrase</p>
            </div>

            <div class="rsvp-pause-track">
                <div id="@UiDomIds.Learn.PauseFill" class="rsvp-pause-fill"></div>
            </div>

            <aside class="rsvp-notes"
                   data-test="@UiTestIds.Learn.NotesPanel"
                   @onkeydown:stopPropagation="true">
                <div class="rsvp-notes-head">
                    <span class="rsvp-notes-title">@Text(UiTextKey.LearnNotesTitle)</span>
                    <span class="rsvp-notes-section" data-test="@UiTestIds.Learn.NotesSection">@CurrentPrepNotesSectionLabel</span>
                </div>
                <textarea class="rsvp-notes-input"
                          rows="3"
                          value="@_prepNoteDraft"
                          placeholder="@Text(UiTextKey.LearnNotesPlaceholder)"
                          aria-label="@Text(UiTextKey.LearnNotesTitle)"
                          @oninput="HandlePrepNoteDraftChanged"
                          data-test="@UiTestIds.Learn.NotesTextarea"></textarea>
                <button class="rsvp-notes-save"
                        type="button"
                        disabled="@(!CanAddPrepNote)"
                        @onclick="AddPrepNoteAsync"
                        data-test="@UiTestIds.Learn.NotesSave">@Text(UiTextKey.LearnNotesSave)</button>
                <div class="rsvp-notes-list" data-test="@UiTestIds.Learn.NotesList">
                    @{
                        var currentNotes = CurrentSectionPrepNotes;
                    }
                    @if (currentNotes.Count == 0)
                    {
                        <p class="rsvp-notes-empty" data-test="@UiTestIds.Learn.NotesEmpty">@Text(UiTextKey.LearnNotesEmpty)</p>
                    }
                    else
                    {
                        @foreach (var note in currentNotes)
                        {
                            <article class="rsvp-note" data-test="@UiTestIds.Learn.NoteItem(note.Id)">
                                <span class="rsvp-note-anchor">@note.AnchorWord</span>
                                <p>@note.Text</p>
                            </article>
                        }
                    }
                </div>
            </aside>
        </div>

        <div class="rsvp-bottom">
            <div class="rsvp-speed">
                <TooltipAnchor OwnerTestId="@UiTestIds.Learn.SpeedDown" Text="@DecreaseSpeedTooltip">
                    <button class="rsvp-btn"
                            @onclick="DecreaseRsvpSpeedAsync"
                            aria-label="@DecreaseSpeedTooltip"
                            data-test="@UiTestIds.Learn.SpeedDown"><UiIcon Kind="UiIconKind.Minus" Size="18" StrokeWidth="2.5m" /></button>
                </TooltipAnchor>
                <div class="rsvp-speed-num"><span id="@UiDomIds.Learn.Speed" data-test="@UiTestIds.Learn.SpeedValue">@_speed</span><small>@Text(UiTextKey.CommonWpm)</small></div>
                <TooltipAnchor OwnerTestId="@UiTestIds.Learn.SpeedUp" Text="@IncreaseSpeedTooltip">
                    <button class="rsvp-btn"
                            @onclick="IncreaseRsvpSpeedAsync"
                            aria-label="@IncreaseSpeedTooltip"
                            data-test="@UiTestIds.Learn.SpeedUp"><UiIcon Kind="UiIconKind.Plus" Size="18" StrokeWidth="2.5m" /></button>
                </TooltipAnchor>
            </div>
            <div class="rsvp-play-band">
                <div class="rsvp-play-side-slot" aria-hidden="true"></div>
                <div class="rsvp-play-row">
                    <TooltipAnchor OwnerTestId="@UiTestIds.Learn.StepBackwardLarge" Text="@BackFiveWordsTooltip">
                        <button class="rsvp-btn"
                                @onclick="StepRsvpBackwardLargeAsync"
                                aria-label="@BackFiveWordsTooltip"
                                data-test="@UiTestIds.Learn.StepBackwardLarge"><UiIcon Kind="UiIconKind.SkipBackward" Size="18" /></button>
                    </TooltipAnchor>
                    <TooltipAnchor OwnerTestId="@UiTestIds.Learn.StepBackward" Text="@BackOneWordTooltip">
                        <button class="rsvp-btn rsvp-btn-sm"
                                @onclick="StepRsvpBackwardAsync"
                                aria-label="@BackOneWordTooltip"
                                data-test="@UiTestIds.Learn.StepBackward"><UiIcon Kind="UiIconKind.ChevronLeft" Size="14" StrokeWidth="2.5m" /></button>
                    </TooltipAnchor>
                    <TooltipAnchor OwnerTestId="@UiTestIds.Learn.PlayToggle" Text="@PlayToggleTooltip">
                        <button class="rsvp-play"
                                id="rsvp-play-btn"
                                @onclick="ToggleRsvpPlaybackAsync"
                                aria-label="@PlayToggleTooltip"
                                aria-pressed="@(_isPlaying ? bool.TrueString.ToLowerInvariant() : bool.FalseString.ToLowerInvariant())"
                                data-test="@UiTestIds.Learn.PlayToggle">
                            <span data-toggle-icon="play" data-test="@UiTestIds.Learn.PlayIcon" hidden="@_isPlaying">
                                <UiIcon Kind="UiIconKind.Play" Size="28" />
                            </span>
                            <span data-toggle-icon="pause" data-test="@UiTestIds.Learn.PauseIcon" hidden="@(!_isPlaying)">
                                <UiIcon Kind="UiIconKind.Pause" Size="28" />
                            </span>
                        </button>
                    </TooltipAnchor>
                    <TooltipAnchor OwnerTestId="@UiTestIds.Learn.StepForward" Text="@ForwardOneWordTooltip">
                        <button class="rsvp-btn rsvp-btn-sm"
                                @onclick="StepRsvpForwardAsync"
                                aria-label="@ForwardOneWordTooltip"
                                data-test="@UiTestIds.Learn.StepForward"><UiIcon Kind="UiIconKind.ChevronRight" Size="14" StrokeWidth="2.5m" /></button>
                    </TooltipAnchor>
                    <TooltipAnchor OwnerTestId="@UiTestIds.Learn.StepForwardLarge" Text="@ForwardFiveWordsTooltip">
                        <button class="rsvp-btn"
                                @onclick="StepRsvpForwardLargeAsync"
                                aria-label="@ForwardFiveWordsTooltip"
                                data-test="@UiTestIds.Learn.StepForwardLarge"><UiIcon Kind="UiIconKind.SkipForward" Size="18" /></button>
                    </TooltipAnchor>
                </div>
                <TooltipAnchor OwnerTestId="@UiTestIds.Learn.LoopToggle" Text="@LoopToggleButtonTitle">
                    <button class="@LoopToggleButtonCssClass"
                            @onclick="ToggleLoopPlaybackAsync"
                            aria-label="@LoopToggleButtonTitle"
                            aria-pressed="@(_isLoopEnabled ? bool.TrueString.ToLowerInvariant() : bool.FalseString.ToLowerInvariant())"
                            data-test="@UiTestIds.Learn.LoopToggle">
                        <UiIcon Kind="UiIconKind.Loop" Size="18" StrokeWidth="2.2m" />
                    </button>
                </TooltipAnchor>
            </div>
            <div class="rsvp-pos"
                 id="@UiDomIds.Learn.ProgressLabel"
                 data-test="@UiTestIds.Learn.ProgressLabel">@_progressLabel</div>
        </div>
    </div>
</div>
